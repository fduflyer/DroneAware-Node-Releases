#!/bin/bash
# DroneAware Node CLI
# Usage: sudo droneaware <command>

GITHUB_REPO="fduflyer/DroneAware-Node-Releases"
INSTALL_DIR="/opt/droneaware"
VERSION_FILE="${INSTALL_DIR}/version"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BOLD='\033[1m'; NC='\033[0m'
info()  { echo -e "  ${GREEN}✓${NC}  $*"; }
warn()  { echo -e "  ${YELLOW}!${NC}  $*"; }
fatal() { echo -e "\n  ${RED}✗  ERROR: $*${NC}\n"; exit 1; }

require_root() { [[ $EUID -eq 0 ]] || fatal "Run with sudo: sudo droneaware $1"; }

# ---------------------------------------------------------------------------
# Config.env additive merge — adds new fields introduced by recent releases
# to an existing config.env, without touching user-customized values.
#
# Pattern for adding a new release's fields:
#   if ! grep -q '^FIELD_NAME=' "$cfg"; then
#       cat >> "$cfg" <<'EOF'
#       ... new fields ...
#       EOF
#       info "..."
#   fi
#
# Each block is idempotent (running update twice is a no-op the second time)
# and cumulative (skipping a version still picks up its additions later).
# A timestamped backup is written before any changes so users can restore.
# ---------------------------------------------------------------------------
migrate_config_env() {
    local cfg="${INSTALL_DIR}/config.env"
    [[ -f "$cfg" ]] || return  # nothing to migrate

    local backed_up=0

    # v1.2.0 additions — channel hopper config
    if ! grep -q '^ADAPTIVE_DWELL=' "$cfg"; then
        [[ "$backed_up" == "0" ]] && cp "$cfg" "${cfg}.bak.$(date +%s)" && backed_up=1
        cat >> "$cfg" <<'EOF'

# ─── Channel hopper (added by droneaware update for v1.2.0+) ───
ADAPTIVE_DWELL=true
# Optional adaptive-hopper tuning (uncomment to override defaults):
# FIXED_CHANNEL=6           # Lock 100% to this channel — overrides adaptive logic
# ACTIVE_WINDOW_SEC=3       # Sticky-mode reset threshold in seconds (default 3.0)
# DWELL_CH6_MS=800          # Primary channel dwell in sweep mode (default 800ms)
# DWELL_PEEK_MS=50          # Peek dwell on channels 1 and 11 (default 50ms)
EOF
        info "Added v1.2.0 channel hopper options to config.env"
    fi

    # v1.1.3 catch-up — GPS_BAUD (missing from configs older than v1.1.3)
    # Harmless when absent (auto-detect runs at startup), but added for
    # config consistency so users can see/override the value.
    if ! grep -q '^GPS_BAUD=' "$cfg"; then
        [[ "$backed_up" == "0" ]] && cp "$cfg" "${cfg}.bak.$(date +%s)" && backed_up=1
        cat >> "$cfg" <<'EOF'

# ─── GPS baud rate (added by droneaware update for v1.1.3+) ───
# Blank = auto-detect at startup (tries 9600 → 38400 → 115200 with NMEA
# checksum validation). Set explicitly to skip detection: GPS_BAUD=9600
GPS_BAUD=
EOF
        info "Added v1.1.3 GPS_BAUD option to config.env"
    fi

    # v1.2.2 additions — 5 GHz scanning (dual-band adapter support)
    if ! grep -q '^WIFI_5G_ENABLED=' "$cfg"; then
        [[ "$backed_up" == "0" ]] && cp "$cfg" "${cfg}.bak.$(date +%s)" && backed_up=1
        cat >> "$cfg" <<'EOF'

# ─── 5 GHz scanning (added by droneaware update for v1.2.2+) ───
# Single dual-band adapter runs a 30s cycle (ASTM-compliant channels only):
#   20s ch6 (2.4 GHz RID) → 10s ch149 (5 GHz RID).
# Requires the adapter to expose channel 149 in monitor mode.
#
# auto  — detect dual-band capability at startup (recommended)
# true  — force-enable (warns and falls back if adapter doesn't support 5 GHz)
# false — force-disable (stay on 2.4 GHz only even if adapter is dual-band)
WIFI_5G_ENABLED=auto

# Off-channel sweep (advanced opt-in). When enabled, the hopper adds brief
# peeks at ch1 and ch11 (1 sec each per cycle) to surface any non-standard
# transmitters that might appear on those channels in the future.
# Empirical fleet data shows ~0% real ch1/ch11 broadcasts today (all observed
# off-band captures are ch6 drift), so the default is OFF — the platform spends
# 100% of cycle time on the channels where compliant RID actually transmits.
# Enable only if you specifically want to chase non-compliant transmitters.
WIFI_OFF_CHANNEL_SWEEP=false
EOF
        info "Added v1.2.2 5 GHz scanning options to config.env"
    fi

    # Future release migration blocks go here.
    # Pattern:
    #   if ! grep -q '^NEW_FIELD=' "$cfg"; then
    #       [[ "$backed_up" == "0" ]] && cp "$cfg" "${cfg}.bak.$(date +%s)" && backed_up=1
    #       cat >> "$cfg" <<'EOF'
    # ... new fields ...
    # EOF
    #       info "Added vX.Y.Z options to config.env"
    #   fi
}

cmd_update() {
    require_root "update"
    echo ""
    echo -e "${BOLD}DroneAware Update${NC}"
    echo ""

    CURRENT=$(cat "$VERSION_FILE" 2>/dev/null || echo "unknown")
    echo "  Checking latest release..."

    # Find the most recent release that actually contains binaries.
    # Installer-only releases (no ble_feeder asset) are skipped.
    LATEST=""
    while IFS= read -r tag; do
        [[ -z "$tag" ]] && continue
        has_binary=$(curl -sf "https://api.github.com/repos/${GITHUB_REPO}/releases/tags/${tag}" \
            | grep '"name"' | grep -c 'ble_feeder' || true)
        if [[ "$has_binary" -gt 0 ]]; then
            LATEST="$tag"
            break
        fi
    done < <(curl -sf "https://api.github.com/repos/${GITHUB_REPO}/releases" \
        | grep '"tag_name"' | cut -d'"' -f4)

    [[ -n "$LATEST" ]] || fatal "Could not reach GitHub or no binary release found — check internet connection."

    echo "  Installed : ${CURRENT}"
    echo "  Latest    : ${LATEST}"
    echo ""

    if [[ "$CURRENT" == "$LATEST" ]]; then
        info "Already up to date."
        echo ""
        return
    fi

    BASE="https://github.com/${GITHUB_REPO}/releases/download/${LATEST}"
    echo "  Downloading binaries..."
    curl -fsSL --retry 3 "${BASE}/ble_feeder"  -o /tmp/da_ble_feeder  || fatal "Failed to download ble_feeder"
    curl -fsSL --retry 3 "${BASE}/wifi_feeder" -o /tmp/da_wifi_feeder || fatal "Failed to download wifi_feeder"
    chmod +x /tmp/da_ble_feeder /tmp/da_wifi_feeder
    info "Downloaded ${LATEST}."

    echo "  Stopping services..."
    systemctl stop droneaware-ble droneaware-wifi 2>/dev/null || true

    # Also update the droneaware CLI itself
    curl -fsSL --retry 3 "${BASE}/droneaware" -o /tmp/da_cli || true
    if [[ -s /tmp/da_cli ]]; then
        chmod +x /tmp/da_cli
    fi

    cp /tmp/da_ble_feeder  "${INSTALL_DIR}/ble_feeder"
    cp /tmp/da_wifi_feeder "${INSTALL_DIR}/wifi_feeder"
    # Update the droneaware CLI itself. Must use atomic rename (mv) instead
    # of in-place cp, because bash is currently READING from this same
    # script file. In-place overwrite would shift bash's file pointer to
    # bytes in the new (different-sized) file → garbage parsing at script
    # end (the v1.2.0 "line 426: syntax error" bug). Atomic rename keeps
    # the open file descriptor pointed at the old inode until bash exits.
    if [[ -s /tmp/da_cli ]]; then
        cp /tmp/da_cli /usr/local/bin/droneaware.new
        chmod +x /usr/local/bin/droneaware.new
        mv /usr/local/bin/droneaware.new /usr/local/bin/droneaware
    fi
    rm -f /tmp/da_ble_feeder /tmp/da_wifi_feeder /tmp/da_cli
    echo "$LATEST" > "$VERSION_FILE"

    # Nodes installed before v1.0.19 have service files pointing to /usr/local/bin/.
    # Symlink both paths to /opt/droneaware/ so the correct binary runs regardless
    # of which path the service file references.
    ln -sf "${INSTALL_DIR}/ble_feeder"  /usr/local/bin/ble_feeder  2>/dev/null || true
    ln -sf "${INSTALL_DIR}/wifi_feeder" /usr/local/bin/wifi_feeder 2>/dev/null || true
    info "Binaries installed."

    # Add any new config.env fields introduced by this release before services
    # restart (so they see the new EnvironmentFile values on the next read).
    #
    # Subtle but load-bearing: bash is still executing from the OLD CLI's
    # open file descriptor at this point (per the atomic-mv pattern from
    # v1.2.1), so calling migrate_config_env directly here runs the OLD
    # CLI's migration code — meaning any migration block we add in THIS
    # release wouldn't actually run until the NEXT update.
    #
    # Fix (v1.3.0): re-exec the newly-installed CLI via a hidden
    # __migrate subcommand, so the NEW CLI's migration code runs now. If
    # that fails for any reason (CLI missing, syntax error, migrate
    # throws), fall back to the in-process call — that's the worst case
    # and matches the pre-v1.3.0 behavior, so we never regress.
    #
    # All migration blocks are idempotent (each `if ! grep -q`-gated), so
    # if both paths somehow run, no harm done.
    migrated_via_new_cli=0
    if [[ -x /usr/local/bin/droneaware ]]; then
        if /usr/local/bin/droneaware __migrate; then
            migrated_via_new_cli=1
        fi
    fi
    if [[ "$migrated_via_new_cli" == "0" ]]; then
        warn "Re-exec of new CLI for migration failed — falling back to in-process migration"
        migrate_config_env
    fi

    systemctl daemon-reload
    systemctl start droneaware-wifi
    if hciconfig 2>/dev/null | grep -q "hci"; then
        systemctl start droneaware-ble
    else
        warn "No Bluetooth adapter detected — skipping droneaware-ble"
    fi
    info "Services restarted."
    echo ""
    info "Update complete — now running ${LATEST}."
    echo ""
}

cmd_status() {
    require_root "status"
    echo ""
    echo -e "${BOLD}DroneAware Node Status${NC}"
    echo ""
    local ver
    ver=$(cat "$VERSION_FILE" 2>/dev/null || echo "unknown")
    echo "  Firmware : ${ver}"
    echo "  Node ID  : $(grep '^NODE_ID=' "${INSTALL_DIR}/config.env" 2>/dev/null | cut -d= -f2 || echo "unknown")"
    echo ""
    for svc in droneaware-ble droneaware-wifi; do
        local state
        state=$(systemctl is-active "$svc" 2>/dev/null)
        if [[ "$state" == "active" ]]; then
            echo -e "  ${GREEN}●${NC}  ${svc}  (running)"
        else
            echo -e "  ${RED}●${NC}  ${svc}  (${state})"
        fi
    done

    echo ""
    # GPS state — read tmpfs state file written by wifi_feeder. Soft-fails
    # if file missing (feeder not yet started, or pre-v1.3.0 binary).
    python3 - <<'PYEOF'
import json, time, sys
try:
    with open("/run/droneaware/gps_state.json") as f:
        s = json.load(f)
except FileNotFoundError:
    print("  GPS      : state unknown (wifi_feeder not running, or pre-v1.3.0 binary)")
    sys.exit(0)
except Exception as e:
    print(f"  GPS      : state file unreadable ({e})")
    sys.exit(0)

status     = s.get("status", "unknown")
device     = s.get("device")
baud       = s.get("baud")
lat        = s.get("lat")
lon        = s.get("lon")
updated_at = s.get("updated_at") or 0
age        = time.time() - updated_at

if age > 120:
    print(f"  GPS      : state stale ({int(age)}s old — wifi_feeder may have stopped)")
elif status == "not_configured":
    print("  GPS      : not configured")
elif status == "device_missing":
    print(f"  GPS      : {device} — configured but device not present")
elif status == "detecting_baud":
    print(f"  GPS      : {device} — detecting baud rate...")
elif status == "no_nmea":
    print(f"  GPS      : {device} — device exists but no valid NMEA detected")
elif status == "reading":
    if baud is not None:
        print(f"  GPS      : {device} @ {baud} baud — reading NMEA, no fix yet")
    else:
        print(f"  GPS      : {device} — reading NMEA, no fix yet")
elif status == "fix":
    if baud is not None:
        print(f"  GPS      : {device} @ {baud} baud — fix acquired (lat={lat}, lon={lon})")
    else:
        print(f"  GPS      : {device} — fix acquired (lat={lat}, lon={lon})")
else:
    print(f"  GPS      : {status}")
PYEOF
    echo ""
}

cmd_logs() {
    local svc="droneaware-wifi"
    [[ "${2:-}" == "ble" ]] && svc="droneaware-ble"
    journalctl -u "$svc" -f
}

cmd_test() {
    require_root "test"

    local dry_run=0
    [[ "${2:-}" == "--dry-run" ]] && dry_run=1

    # Read node config
    local cfg="${INSTALL_DIR}/config.env"
    local node_id lat lon iface server_url token
    node_id=$(   grep '^NODE_ID='      "$cfg" 2>/dev/null | cut -d= -f2)
    lat=$(       grep '^NODE_LAT='     "$cfg" 2>/dev/null | cut -d= -f2)
    lon=$(       grep '^NODE_LON='     "$cfg" 2>/dev/null | cut -d= -f2)
    iface=$(     grep '^WIFI_ADAPTER=' "$cfg" 2>/dev/null | cut -d= -f2)
    server_url=$(grep '^SERVER_URL='   "$cfg" 2>/dev/null | cut -d= -f2)
    iface="${iface:-wlan1}"
    server_url="${server_url:-https://api.droneaware.io/api}"
    token=$(cat /etc/droneaware/token 2>/dev/null | tr -d '[:space:]')
    [[ -z "$token" ]] && fatal "No node credential found. Re-run the installer to enroll this node."

    # WiFi adapter must exist before we contact the server (avoids wasting a
    # rate-limit slot) or run the embedded transmitter (avoids ENODEV crash on
    # missing iface). Fail fast with an actionable message.
    if [[ -z "$iface" || ! -d "/sys/class/net/${iface}" ]]; then
        echo ""
        echo -e "  ${RED}✗  Cannot run test — WiFi adapter '${iface:-<none>}' not present.${NC}"
        echo ""
        echo "  This command transmits a Remote ID beacon, which requires a USB"
        echo "  monitor-mode adapter (e.g. Alfa AWUS036N)."
        echo ""
        echo "  Connect an adapter and re-run the installer to enable WiFi testing."
        echo ""
        exit 1
    fi

    # Fall back to GPS fix if available and static coords are missing
    if [[ -z "$lat" || "$lat" == "0" || -z "$lon" || "$lon" == "0" ]]; then
        local gps_dev
        gps_dev=$(grep '^GPS_DEVICE=' "$cfg" 2>/dev/null | cut -d= -f2)
        if [[ -n "$gps_dev" && -e "$gps_dev" ]]; then
            local nmea
            nmea=$(stty -F "$gps_dev" 4800 2>/dev/null; timeout 8 cat "$gps_dev" 2>/dev/null \
                | grep -m1 '^\$GPRMC.*,A,')
            if [[ -n "$nmea" ]]; then
                lat=$(echo "$nmea" | python3 -c "
import sys, re
parts = sys.stdin.read().strip().split(',')
d=int(float(parts[3])/100); m=float(parts[3])-d*100
lat=round(d+m/60,6)
if parts[4]=='S': lat=-lat
d=int(float(parts[5])/100); m=float(parts[5])-d*100
lon=round(d+m/60,6)
if parts[6].split('*')[0]=='W': lon=-lon
print(lat, lon)" | awk '{print $1}')
                lon=$(echo "$nmea" | python3 -c "
import sys
parts = sys.stdin.read().strip().split(',')
d=int(float(parts[5])/100); m=float(parts[5])-d*100
lon=round(d+m/60,6)
if parts[6].split('*')[0]=='W': lon=-lon
print(lon)")
            fi
        fi
    fi

    [[ -z "$lat" || "$lat" == "0" ]] && \
        fatal "No location configured. Set NODE_LAT/NODE_LON in /opt/droneaware/config.env first."

    # Build test UAS_ID: TESTFA + up to 8 chars of node_id (uppercase, alphanumeric)
    local test_id
    test_id="TESTFA$(echo "$node_id" | tr '[:lower:]' '[:upper:]' | tr -dc 'A-Z0-9' | \
        head -c 8 | awk '{printf "%-8s", $0}' | tr ' ' '0')"

    echo ""
    echo -e "${BOLD}DroneAware Test Flight${NC}"
    echo ""
    echo "  Node     : ${node_id}"
    echo "  Test ID  : ${test_id}"
    echo "  Location : ${lat}, ${lon}"
    echo "  Interface: ${iface}"
    echo ""

    # Ask the server for permission — it is the source of truth for rate limits
    echo "  Checking with server..."
    local start_resp http_status start_body
    start_resp=$(curl -s --max-time 10 \
        -o /tmp/da_test_start.json \
        -w "%{http_code}" \
        -X POST \
        -H "X-Node-Token: ${token}" \
        "${server_url}/nodes/${node_id}/test/start" 2>/dev/null) || true
    http_status="$start_resp"
    start_body=$(cat /tmp/da_test_start.json 2>/dev/null || true)
    rm -f /tmp/da_test_start.json

    case "$http_status" in
        200)
            local remaining started_at
            remaining=$(echo "$start_body" | python3 -c \
                "import sys,json; d=json.load(sys.stdin); print(d.get('remaining_in_hour',''))" 2>/dev/null || true)
            started_at=$(echo "$start_body" | python3 -c \
                "import sys,json; d=json.load(sys.stdin); print(d.get('started_at',''))" 2>/dev/null || true)
            info "Test authorized by server.${remaining:+  (${remaining} more allowed this hour)}"
            [[ -n "$started_at" ]] && echo "  Started    : ${started_at}"
            ;;
        401)
            fatal "Node authentication failed — re-run installer if this persists."
            ;;
        403)
            local msg
            msg=$(echo "$start_body" | python3 -c \
                "import sys,json; print(json.load(sys.stdin).get('detail','Access denied.'))" 2>/dev/null || true)
            fatal "${msg:-Access denied.}"
            ;;
        404)
            fatal "Node ID not recognized — re-run installer."
            ;;
        429)
            local user_msg
            user_msg=$(echo "$start_body" | python3 -c \
                "import sys,json
d=json.load(sys.stdin)
detail=d.get('detail',{})
print(detail.get('message', str(detail)))" 2>/dev/null || true)
            echo -e "\n  ${YELLOW}!${NC}  ${user_msg:-Rate limit reached. Try again later.}"
            echo ""
            exit 1
            ;;
        000|"")
            fatal "Could not reach server. Check internet connection."
            ;;
        *)
            fatal "Unexpected server response (HTTP ${http_status}). Try again later."
            ;;
    esac

    if [[ "$dry_run" == "1" ]]; then
        info "Dry run — server says OK. No transmission sent."
        echo ""
        exit 0
    fi

    echo ""
    echo "  Transmitting 60-second test flight..."
    echo "  Check your My Nodes page — a test detection should appear within 30s."
    echo ""

    # Transmit test beacons via Python (embedded)
    python3 - "$iface" "$lat" "$lon" "$test_id" <<'PYEOF'
import sys, socket, struct, time, math

iface, lat, lon, uas_id = sys.argv[1], float(sys.argv[2]), float(sys.argv[3]), sys.argv[4]

# --- ODID builders (ASTM F3411-22a correct byte layout) ---

def build_basic_id(uas_id):
    msg = bytearray(25)
    msg[0] = 0x00          # type=Basic ID, protocol version=0
    msg[1] = 0x12          # id_type=1 (Serial), ua_type=2 (Multirotor)
    msg[2:2+len(uas_id)] = uas_id.encode('ascii')[:20]
    return bytes(msg)

def build_location(lat, lon, alt_geo=0.0, vspeed=0.0, heading=0.0):
    # F3411-22a Location message byte layout:
    # 0: type+version  1: status byte  2: track direction (0-179)
    # 3: speed  4: vert_speed  5-8: lat  9-12: lon
    # 13-14: pressure_alt  15-16: geodetic_alt  17-18: height_agl
    # 19-24: accuracy/timestamp/reserved
    msg = bytearray(25)
    msg[0] = 0x10  # type=Location/Vector

    # Status byte: bit0=speed_mult(0=x0.25), bit1=EW_dir, bit2=height_type
    ew_dir = 1 if heading >= 180 else 0
    msg[1] = (ew_dir << 1)

    # Byte 2: track direction 0-179° (EW bit adds 180° for full 360)
    msg[2] = int(heading) % 180

    # Byte 3: speed (stationary = 0)
    msg[3] = 0

    # Byte 4: vertical speed encoded as (vspeed + 62) / 0.5
    msg[4] = max(0, min(254, int((vspeed + 62.0) / 0.5)))

    # Bytes 5-8: latitude
    struct.pack_into('<i', msg, 5, int(lat * 1e7))

    # Bytes 9-12: longitude
    struct.pack_into('<i', msg, 9, int(lon * 1e7))

    # Bytes 13-14: pressure altitude = (alt + 1000) / 0.5
    alt_enc = max(0, int((alt_geo + 1000.0) / 0.5))
    struct.pack_into('<H', msg, 13, alt_enc)

    # Bytes 15-16: geodetic altitude
    struct.pack_into('<H', msg, 15, alt_enc)

    # Bytes 17-18: height AGL — raw 2002 decodes to 1.0m
    # (server treats raw 0x0000 as unpopulated/None)
    struct.pack_into('<H', msg, 17, 2002)

    return bytes(msg)

def build_system_msg(op_lat, op_lon, alt_takeoff=0.0):
    # F3411-22a System message byte layout (server-verified offsets):
    # 0: type+version  1: op_location_type+classification
    # 2-5: op_lat  6-9: op_lon
    # 10-11: area_count  12: area_radius
    # 13-14: alt_takeoff_geo
    msg = bytearray(25)
    msg[0] = 0x40  # type=System
    msg[1] = 0x00  # op_location_type=0 (takeoff), classification=0
    struct.pack_into('<i', msg, 2, int(op_lat * 1e7))   # operator lat
    struct.pack_into('<i', msg, 6, int(op_lon * 1e7))   # operator lon
    struct.pack_into('<H', msg, 10, 1)                   # area_count = 1
    msg[12] = 0                                          # area_radius = 0 (point)
    struct.pack_into('<H', msg, 13, max(0, int((alt_takeoff + 1000.0) / 0.5)))
    return bytes(msg)

def build_message_pack(messages):
    pack = bytearray(3 + 25 * len(messages))
    pack[0] = 0xF0; pack[1] = 25; pack[2] = len(messages)
    for i, m in enumerate(messages):
        pack[3 + i*25:3 + (i+1)*25] = m[:25]
    return bytes(pack)

def build_beacon(src_mac, payload):
    radiotap = struct.pack('<BBHI', 0, 0, 8, 0)
    fc = bytes([0x80, 0x00])
    dur = bytes([0x00, 0x00])
    da = bytes([0xFF]*6)
    rid_data = bytes([0xFA, 0x0B, 0xBC, 0x0D]) + payload
    rid_ie = bytes([0xDD, len(rid_data)]) + rid_data
    body = (bytes(8) + struct.pack('<H', 100) + bytes([0x01, 0x00]) +
            bytes([0x00, 0x00]) +
            bytes([0x01, 0x08, 0x82, 0x84, 0x8B, 0x96, 0x24, 0x30, 0x48, 0x6C]) +
            rid_ie)
    frame = radiotap + fc + dur + da + src_mac + src_mac + bytes([0x00, 0x00]) + body
    return frame

# Flight path: paper-airplane shape (simplified) centred on node location
# Offsets in degrees (~0.0001 deg ≈ 11m)
R = 0.0004   # ~44m radius
waypoints = []
# Nose of plane (forward point)
waypoints.append((lat + R*1.5, lon))
# Right wing tip
waypoints.append((lat - R*0.5, lon + R*1.2))
# Tail centre
waypoints.append((lat - R*0.8, lon))
# Left wing tip
waypoints.append((lat - R*0.5, lon - R*1.2))
# Back to nose
waypoints.append((lat + R*1.5, lon))
# Tight circle around centre to finish
for i in range(8):
    angle = math.radians(i * 45)
    waypoints.append((lat + R*0.4*math.sin(angle), lon + R*0.4*math.cos(angle)))

src_mac = bytes([0x60, 0x60, 0x1F, 0x00, 0x01, 0x02])
basic_id  = build_basic_id(uas_id)
system_msg = build_system_msg(lat, lon)   # operator = node location

sock = socket.socket(socket.AF_PACKET, socket.SOCK_RAW)
sock.bind((iface, 0))

steps    = len(waypoints)
interval = 60.0 / steps

for i, (wlat, wlon) in enumerate(waypoints):
    location = build_location(wlat, wlon, alt_geo=0.0, vspeed=0.0, heading=0.0)
    pack = build_message_pack([basic_id, location, system_msg])
    frame = build_beacon(src_mac, pack)

    # Send 3 times to cover channel hopper cycle
    for _ in range(3):
        try:
            sock.send(frame)
        except Exception:
            pass
        time.sleep(0.3)

    print(f"  [{i+1}/{steps}] lat={wlat:.6f} lon={wlon:.6f}")
    time.sleep(max(0, interval - 0.9))

sock.close()
print("\n  Transmission complete.")
PYEOF

    # Check local detection ring buffer (per-channel breakdown so the
    # operator can see whether 2.4 GHz and 5 GHz radio paths both received).
    echo ""
    echo "  Checking local detection buffer..."
    sleep 3

    local stats
    stats=$(python3 - "$test_id" 2>/dev/null <<'PYJSON'
import json, sys
test_id = sys.argv[1]
counts = {}
total = 0
try:
    with open("/run/droneaware/detections.jsonl") as f:
        for line in f:
            try:
                e = json.loads(line)
            except json.JSONDecodeError:
                continue
            # LocalPublisher flattens the decoded sub-message into top-level
            # keys: 'id' holds uas_id (only present for Basic ID events).
            if e.get("id") != test_id:
                continue
            total += 1
            ch = e.get("channel")
            counts[ch] = counts.get(ch, 0) + 1
except FileNotFoundError:
    pass
print(total, counts.get(6, 0), counts.get(149, 0))
PYJSON
)

    local total ch6 ch149
    read -r total ch6 ch149 <<< "${stats:-0 0 0}"

    if [[ "$total" -eq 0 ]]; then
        warn "No local detection found yet — the server may still be processing."
        warn "Check your My Nodes page in 30 seconds."
    else
        info "Local detection confirmed — ${total} events captured"
        echo "       2.4 GHz (ch  6) : ${ch6}"
        echo "       5 GHz  (ch 149) : ${ch149}"
        if [[ "$ch6" -gt 0 && "$ch149" -gt 0 ]]; then
            info "Both bands receiving — radio fully functional."
        fi
    fi
    echo ""
}

case "$1" in
    update)  cmd_update ;;
    status)  cmd_status ;;
    logs)    cmd_logs "$@" ;;
    test)    cmd_test "$@" ;;
    __migrate)
        # Internal subcommand used by cmd_update for post-install config
        # migration. The double-underscore prefix is a convention signaling
        # "private — operators shouldn't need to call this." Intentionally
        # NOT mentioned in the help text below.
        #
        # Safe to call manually for testing — it's just migrate_config_env,
        # which is idempotent and writes a timestamped backup of config.env
        # before any modification.
        require_root "__migrate"
        migrate_config_env
        ;;
    *)
        echo ""
        echo -e "${BOLD}DroneAware Node CLI${NC}"
        echo ""
        echo "  Usage: sudo droneaware <command>"
        echo ""
        echo "  Commands:"
        echo "    update       Download and install the latest firmware"
        echo "    status       Show service status and firmware version"
        echo "    logs         Tail live logs  (wifi by default, or: droneaware logs ble)"
        echo "    test         Transmit a 60-second test flight and verify detection"
        echo "    test --dry-run  Check rate-limit availability without transmitting"
        echo ""
        ;;
esac
